# Docker Compose reads .env from the repository root.
# Copy this file to .env on the deployment host and set a real strong password.

POSTGRES_DB=melodex
POSTGRES_USER=melodex
POSTGRES_PASSWORD=change-this-to-a-long-random-password

# Music recognition is disabled by default.
# AudD:
# MUSIC_DL_RECOGNITION_PROVIDER=audd
# MUSIC_DL_AUDD_ENDPOINT=https://api.audd.io/
# MUSIC_DL_AUDD_TOKEN=replace-with-audd-token
# MUSIC_DL_AUDD_RETURN=apple_music,spotify
#
# ACRCloud:
# MUSIC_DL_RECOGNITION_PROVIDER=acrcloud
# MUSIC_DL_ACRCLOUD_ENDPOINT=https://your-host/v1/identify
# MUSIC_DL_ACRCLOUD_ACCESS_KEY=replace-with-acrcloud-access-key
# MUSIC_DL_ACRCLOUD_ACCESS_SECRET=replace-with-acrcloud-access-secret
#
# Optional limits:
# MUSIC_DL_RECOGNITION_TIMEOUT=20s
# MUSIC_DL_RECOGNITION_MAX_BYTES=10485760
# MUSIC_DL_RECOGNITION_RATE_LIMIT_PER_MINUTE=10
